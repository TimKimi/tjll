# =============================================================================
# tjll 配置参考（仓库根目录）
#
# 用法：
#   1. cp .env.example .env
#   2. 在 .env 中填写 [必填] 项，其他按需覆盖
#   3. .env 已被 .gitignore 排除，不会提交
#
# 标记说明：
#   [必填]   — 无安全默认值，必须自己设置
#   [可选]   — 有合理默认值，按需覆盖
# =============================================================================

# =============================================================================
# [必填] 无默认值，每个开发环境必须自己设置
# =============================================================================

# Yelp Fusion API 密钥（https://www.yelp.com/developers）
# CLIENT_ID=<your-yelp-client-id>
# YELP_API=<your-yelp-api-key>

# LLM API 密钥（默认对接 DeepSeek）
# API_KEY=<your-llm-api-key>

# JWT 签名密钥（生产环境务必使用高强度随机串）
# JWT_SECRET=<your-jwt-secret>

# SMTP 邮件服务器（密码找回功能用）
# SMTP_HOST=smtp.example.com
# SMTP_USER=<your-smtp-user>
# SMTP_PASSWORD=<your-smtp-password>
# SMTP_FROM=noreply@example.com

# =============================================================================
# [可选] 有安全默认值，通常不需要修改
# =============================================================================

# ---- 服务器 ----
# APP_HOST=127.0.0.1
# APP_PORT=8000
# APP_BASE_URL=        # 外部地址（反代时需手动设置，留空自动推导）

# ---- PostgreSQL（与 docker-compose.yml 一致）----
# DATABASE_URL=postgresql+asyncpg://tjll:tjll_dev@localhost:5432/tjll
# DATABASE_ECHO=false          # true = 打印 SQL 日志

# ---- Redis（对话历史缓存）----
# redis_host=localhost
# redis_port=6379
# redis_db=0
# redis_password=Jianyan_01
# redis_history_ttl=86400      # 过期时间（秒），24h

# ---- LLM 参数 ----
# BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-v4-flash
# LLM_GENERATE_TEMPERATURE=0.7
# LLM_REWRITE_TEMPERATURE=0.3
# LLM_TIMEOUT=120
# LLM_MAX_RETRIES=2

# ---- JWT ----
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440       # 24 小时
# JWT_REFRESH_EXPIRE_DAYS=7
# EMAIL_CHECK_DELIVERABILITY=false

# ---- 邮件发送（密码找回）----
# SMTP_PORT=587
# SMTP_USE_TLS=true
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30   # 重置链接有效期（分钟）

# ---- OpenSearch（与 docker-compose.yml 一致）----
# OPENSEARCH_HOST=localhost
# OPENSEARCH_PORT=9200
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=Jianyan_01
# OPENSEARCH_USE_SSL=true
# OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_INDEX=yelp_biz_v1
# OPENSEARCH_INSIGHT_INDEX=user_insight_v1

# ---- Embedding / Rerank 模型路径（相对 backend/）----
# EMBEDDING_MODEL_PATH=rag/models/bge-base-zh-v1.5
# RERANK_MODEL_PATH=rag/models/bge-reranker-v2-m3
# EMBEDDING_DEVICE=cuda         # cuda / cpu
# RERANK_USE_FP16=true

# ---- RAG 切分与检索 ----
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# INSIGHT_CHUNK_SIZE=800        # 用户洞察拼接/切分目标长度
# RETRIEVAL_TOP_K=10            # 初筛返回条数
# RERANK_TOP_N=3                # 精排后返回条数
# EMBEDDING_DIMS=768            # 与 bge-base-zh-v1.5 一致
# HYBRID_PIPELINE_NAME=rag_hybrid_pipeline
# HYBRID_BM25_WEIGHT=0.3
# HYBRID_VECTOR_WEIGHT=0.7

# ---- MinerU / ModelScope ----
# MINERU_MODEL_SOURCE=modelscope
# MODELSCOPE_CACHE_PATH=
# MINERU_PIPELINE_MODEL_PATH=models/OpenDataLab--PDF-Extract-Kit-1.0/snapshots/master
# MINERU_VLM_MODEL_PATH=models/OpenDataLab--MinerU2.5-Pro-2605-1.2B/snapshots/master
# MINERU_BACKEND=pipeline
# MINERU_METHOD=auto

# ---- MinerU 数据目录（相对 backend/）----
# MINERU_OUTPUT_PATH=data/mineru-output
# PDFS_PATH=data/pdfs

# ---- Yelp 数据集路径（相对仓库根目录）----
# YELP_DATASET_DIR=data/yelp-dataset
# YELP_ZIP_PATH=data/Yelp-JSON.zip
# YELP_BATCH_SIZE=500

# ---- 日志 ----
# LOG_DIR=logs                   # 输出目录（相对 backend/）
# LOG_LEVEL=INFO                 # DEBUG / INFO / WARNING / ERROR
