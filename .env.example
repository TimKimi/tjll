# =============================================================================
# tjll 配置模板（仓库根目录）
# 本地用法：Copy-Item .env.example .env（生成 .env，勿提交）
# 模型/数据路径相对 backend/ 解析
# =============================================================================

# ---- Yelp ----
CLIENT_ID=Am-ePayOY2RlXnsW6KSQSg
YELP_API=64cPk2G2rTChWjBq3MgzDJcqX8_5W2xdtVGiUliKM7NVwDUZaV99EqWFAViL3TzWUGOC96Xp6RGZWHjnk3vZDWhdNISr16vZCmnmWxnx0M9kAi52grFq60t0FhVWanYx

# ---- PostgreSQL（与 docker-compose.yml 中 db 一致）----
DATABASE_URL=postgresql+asyncpg://tjll:tjll_dev@localhost:5432/tjll
DATABASE_ECHO=false

# ---- 服务器 ----
APP_HOST=127.0.0.1
APP_PORT=8000

# ---- LLM ----
API_KEY=your_api_key_here
BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_GENERATE_TEMPERATURE=0.7
LLM_REWRITE_TEMPERATURE=0.3
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# ---- OpenSearch（与 docker-compose.yml 一致）----
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Jianyan_01
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX=rag_kb_v1

# ---- Redis（对话历史，需 redis-stack）----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=Jianyan_01
REDIS_HISTORY_TTL=86400

# ---- 项目内模型（相对 backend/；权重不入 git）----
EMBEDDING_MODEL_PATH=RAG/models/bge-base-zh-v1.5
RERANK_MODEL_PATH=RAG/models/bge-reranker-v2-m3
EMBEDDING_DEVICE=your_embedding_device_here_cuda_or_cpu
RERANK_USE_FP16=true

# ---- MinerU / ModelScope ----
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_CACHE_PATH=your_modelscope_cache_path_here
MINERU_PIPELINE_MODEL_PATH=models/OpenDataLab--PDF-Extract-Kit-1.0/snapshots/master
MINERU_VLM_MODEL_PATH=models/OpenDataLab--MinerU2.5-Pro-2605-1.2B/snapshots/master
MINERU_BACKEND=pipeline
MINERU_METHOD=auto

# ---- 数据目录（相对 backend/）----
MINERU_OUTPUT_PATH=data/mineru-output
PDFS_PATH=data/pdfs

# ---- RAG 切分与检索 ----
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=10
RERANK_TOP_N=3
EMBEDDING_DIMS=768
HYBRID_PIPELINE_NAME=rag_hybrid_pipeline
HYBRID_BM25_WEIGHT=0.3
HYBRID_VECTOR_WEIGHT=0.7
