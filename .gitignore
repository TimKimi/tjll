# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# IDE / stubgen 旁路生成的 stub（会遮蔽真实 .py，导致 mypy attr-defined）
backend/**/*.pyi

# Virtual environments
.venv

#frontend
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
.DS_Store
dist
dist-ssr
coverage
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

*.tsbuildinfo

.eslintcache

# Cypress
/cypress/videos/
/cypress/screenshots/

# Vitest
__screenshots__/

# Vite
*.timestamp-*-*.mjs

# Sources
/frontend/public/images/
# lint_cache
.*_cache

# Local machine configs (do not push)
.python-version.local

# Coverage reports (regenerated every run)
.coverage
.coverage.*
htmlcov/

# Root secrets; commit .env.example only
.env
!.env.example
backend/.env
backend/.env.*

# Runtime logs (never commit, regenerated at runtime)
logs/

# Model weights under backend/rag: keep placeholders only
backend/rag/models/**
!backend/rag/models/**/
!backend/rag/models/**/.gitkeep
!backend/rag/models/**/README.md
!backend/rag/models/README.md
!backend/rag/models/**/config.local.example.toml

# Optional llama.cpp binaries (Windows CUDA); keep README / .gitkeep only
backend/rag/tools/**
!backend/rag/tools/**/
!backend/rag/tools/**/.gitkeep
!backend/rag/tools/**/README.md

# ModelScope cache (never commit)
modelscope/
../modelscope/

# Runtime outputs (backend-local) — Python package under backend/data/ is tracked
backend/data/*.db
backend/data/*.csv
backend/data/*.jsonl
backend/data/*.json
backend/data/*.zip
# Yelp dataset zip, tar, extracted files (not code) — leading / = root only
/data/

# Local scratch scripts
format.py

# Windows reserved device name (sometimes created by shell redirect)
nul

# User-uploaded files (avatars, documents, etc.)
backend/static/avatars/*
!backend/static/avatars/.gitkeep
backend/static/file/*
!backend/static/file/.gitkeep

# Editor local settings (conda interpreter path is machine-specific)
.vscode/
