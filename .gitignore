# Cypress
/cypress/videos/
/cypress/screenshots/

# Vitest
__screenshots__/

# Vite
*.timestamp-*-*.mjs

# Sources
/frontend/public/images/
# lint_cache
.*_cache

# Local machine configs (do not push)
.python-version.local

# Root secrets; commit .env.example only
.env
!.env.example
backend/.env
backend/.env.*

# Model weights under backend/RAG: keep placeholders only
backend/RAG/models/**
!backend/RAG/models/**/
!backend/RAG/models/**/.gitkeep
!backend/RAG/models/**/README.md
!backend/RAG/models/README.md

# ModelScope cache (never commit)
modelscope/
../modelscope/

# Runtime outputs (backend-local) — Python package under backend/data/ is tracked
backend/data/*.db
backend/data/*.csv
backend/data/*.jsonl
backend/data/*.json
# Yelp dataset zip, tar, extracted files (not code) — leading / = root only
/data/

# Local scratch scripts
format.py

# Windows reserved device name (sometimes created by shell redirect)
nul

# Editor local settings (conda interpreter path is machine-specific)
.vscode/
